{
  "manifest_version": 3,
  "name": "SandCat",
  "version": "1.0.0",
  "permissions": [
  "storage",
  "tabs",
  "scripting",
  "clipboardRead",
  "activeTab",
  "webNavigation"
],
  "host_permissions": [
    "https://davidmegginson.github.io/*",
    "https://www.faa.gov/*",
    "https://aeronav.faa.gov/*",
    "https://nfdc.faa.gov/*",
    "https://*.labelbox.com/*",
    "https://www.airnav.com/*",
    "https://opennav.com/*",
    "https://plan.foreflight.com/*",
    "https://globe.adsbexchange.com/*",
    "https://ourairports.com/*"
  ],

  "icons": {
  "16": "sandcat-icon-16.png",
  "32": "sandcat-icon-32.png",
  "48": "sandcat-icon-48.png",
  "128": "sandcat-icon-128.png"
},
  "action": {
    "default_title": "SandCat 1.0",
    "default_icon":{
    "16": "sandcat-icon-16.png",
    "32": "sandcat-icon-32.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "web_accessible_resources": [
{
  "resources": [
    "cifp.zip",
    "popup.html",
    "adsb_hook.js",
    "adsb_bridge.js",
        "sandcat-icon-32.png",
              "airports.js",
      "search.js",
      "aircraft-hints.json",
      "aircraft-locations.json",
          "waypoints.json",
    "navaids.js"
  ],
  "matches": ["<all_urls>"],
  "allFrames": true
}
],
"content_scripts": [
  {
    "matches": ["<all_urls>"],
    "js": ["labelbox_grab_id.js", "adsb_bridge.js"],
    "run_at": "document_idle",
    "all_frames": true
  }
]
}